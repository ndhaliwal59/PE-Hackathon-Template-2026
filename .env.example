FLASK_DEBUG=true

# Silver: Discord incoming webhook URL for Alertmanager (optional locally; set a real URL for live notifications)
DISCORD_WEBHOOK_URL=

# Enable incident drill routes under /simulation (see scripts/incident/). Never use in production.
INCIDENT_SIMULATION_ENABLED=false

DATABASE_NAME=hackathon_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
