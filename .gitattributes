# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must always use LF
*.sh text eol=lf

# Python and other source files use LF
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Dockerfiles and configuration files use LF
Dockerfile text eol=lf
*.conf text eol=lf

# Batch and PowerShell scripts use CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf